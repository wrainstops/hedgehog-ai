{
  "id": "weather-cn",
  "version": "1.0.0",
  "name": "天气查询（中国城市）",
  "description": "查询中国城市的当前天气（使用 wttr.in 免费 API）",
  "runtime": "http-proxy",
  "permissions": {
    "network": ["https://wttr.in"]
  },
  "tools": [
    {
      "name": "get_weather",
      "description": "查询指定城市的当前天气",
      "endpoint": "https://wttr.in/{city}?format=j1",
      "method": "GET",
      "input_schema": {
        "type": "object",
        "properties": {
          "city": {
            "type": "string",
            "description": "城市名，如 beijing / shanghai / guangzhou"
          }
        },
        "required": ["city"]
      },
      "response_path": "current_condition.0"
    }
  ]
}
